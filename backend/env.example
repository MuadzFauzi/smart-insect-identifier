# ============================================================
# env.example — Salin file ini menjadi .env
# JANGAN commit file .env ke GitHub!
# ============================================================

# API Key Gemini — dapatkan gratis di https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Aktifkan GoogleSearch grounding (true/false)
# Jika true, Gemini akan mencari info terbaru dari internet
USE_GOOGLE_SEARCH=false
