# ============================================================
# .gitignore — Smart Insect Identifier
# ============================================================

# Environment — JANGAN PERNAH commit ini!
.env
*.env

# Virtual Environment
venv/
env/
.venv/

# Model files (ukuran besar, tidak perlu di-commit)
backend/artifacts/*.pt
backend/artifacts/*.pth
# Tapi metadata boleh di-commit
!backend/artifacts/model_metadata.json
!backend/artifacts/.gitkeep

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Node.js
node_modules/
.next/
out/
.turbo/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Dataset (jangan upload ke GitHub)
datasets/
*.csv
